# ora2tidb.conf.example —— Oracle 存储过程 → TiDB 转换工具配置模板（对齐设计文档 §4.4）。
# 复制为 ora2tidb.conf 并按实际填写；ora2tidb.conf 被 .gitignore 忽略，不会提交。

# ===== Oracle 连接（export 导出 + compare 对比）=====
ORACLE_USER=your_ora_user
ORACLE_PASS=your_ora_pass
ORACLE_HOST=ora-host
ORACLE_PORT=1521
ORACLE_SERVICE=ORCLPDB1
ORACLE_SCHEMA=            # 留空则取 ORACLE_USER
# Oracle 数据库字符集（与 NLS_CHARACTERSET 一致），用于 sqlplus 客户端编码转换
# 执行 SELECT value FROM NLS_DATABASE_PARAMETERS WHERE PARAMETER='NLS_CHARACTERSET' 查看
# 常见值：AL32UTF8（UTF-8）、ZHS16GBK（中文 GBK）、JA16SJIS（日文）
ORACLE_CHARSET=AL32UTF8

# ===== TiDB 连接（compare 对比 + capability 探针；TiDB 兼容 MySQL 协议）=====
TIDB_USER=root
TIDB_PASS=
TIDB_HOST=tidb-host
TIDB_PORT=4000
TIDB_DB=test

# ===== 输出目录（相对路径基于项目根，也可填绝对路径）=====
EXPORT_DIR=exported
CONVERTED_DIR=converted
REPORT_DIR=reports

# ===== export 导出对象类型（冒号分隔，因 'PACKAGE BODY' 含空格）=====
# 留空走默认：PROCEDURE:FUNCTION:PACKAGE BODY:PACKAGE
# convert.sh 对 PROCEDURE/FUNCTION 直接转换；PACKAGE BODY 经 _split_package_body
# 拆分为独立子程序；PACKAGE spec（仅声明）只导出不自动转换。
EXPORT_OBJECT_TYPES=

# ===== compare 参数（M3）=====
# 用例目录（测试语料库 cases/*.cases），warm-up 后重复 N 次取 avg/p50/p99
CASES_DIR=
PERF_WARMUP=3
PERF_REPEAT=10
# compare 前两端重置的序列（逗号分隔）——harness-owned 确定性：两端 DROP/CREATE SEQUENCE 同起点，
# 覆盖 NEXTVAL 类非确定值（@架构师 原则：确定性是 harness 属性，非 per-user 手动步骤）。
COMPARE_RESET_SEQUENCES=
